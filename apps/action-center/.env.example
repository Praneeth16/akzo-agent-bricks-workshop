# Local dev only. In Databricks Apps the service principal auths automatically and
# these are set via app.yaml — you do NOT need this file in the deployed app.

# CLI profile used by the databricks-sdk WorkspaceClient for local auth.
DATABRICKS_CONFIG_PROFILE=<your-profile>

# Governed compute.
DATABRICKS_WAREHOUSE_ID=<your-warehouse-id>

# Lakebase (managed Postgres) — the action plane store.
LAKEBASE_INSTANCE=<your-lakebase-instance>
LAKEBASE_DBNAME=databricks_postgres
LAKEBASE_SCHEMA=akzo
